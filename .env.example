# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=         # BotFather token for @ProbBrain_bot
TELEGRAM_CHANNEL_ID=        # Channel to publish signals, e.g. @ProbBrain or -100xxxxxxxxxx
TELEGRAM_WEBHOOK_URL=       # Your public HTTPS URL (leave empty for polling mode)
WEBHOOK_PORT=8443
WEBHOOK_PATH=/webhook

# ── Pro subscribers ────────────────────────────────────────────────────────────
PRO_USER_IDS=               # Comma-separated Telegram user IDs with Pro access

# ── Dub.co affiliate ──────────────────────────────────────────────────────────
DUB_API_KEY=                # Dub.co API key (Settings → API Keys)
DUB_WORKSPACE_ID=           # Dub.co workspace ID
DUB_DOMAIN=dub.sh           # Or your custom domain configured in Dub
POLYMARKET_REFERRAL_CODE=probbrain

# Short-link slugs (set after running config/dub.py::provision_affiliate_links)
DUB_LINK_TELEGRAM_CHANNEL=https://dub.sh/pb-tg
DUB_LINK_TELEGRAM_BOT=https://dub.sh/pb-bot
DUB_LINK_TWITTER=https://dub.sh/pb-x

# ── Dashboard ──────────────────────────────────────────────────────────────────
DASHBOARD_URL=https://vpjonny.github.io/probbrain/   # GitHub Pages dashboard URL
X_PROFILE_URL=https://x.com/ProbBrain   # X profile link (appended to every Telegram post)

# ── Scanner ────────────────────────────────────────────────────────────────────
SCANNER_OUTPUT_DIR=data
SCANNER_MAX_SIGNALS=5

# ── Polymarket Builders Program ───────────────────────────────────────────────
POLYMARKET_BUILDERS_API_KEY=   # Builder API key from builders.polymarket.com
# Sent as POLY_BUILDER_API_KEY header on all Gamma API requests.
# Attributes scanned market traffic to ProbBrain for weekly USDC reward calculation.

# ── X / Twitter ───────────────────────────────────────────────────────────────
# All four values required for posting. Find them in:
# Twitter Developer Portal → Your App → Keys and Tokens
X_CONSUMER_KEY=                # API Key (app-level)
X_CONSUMER_SECRET=             # API Key Secret (app-level)
X_ACCESS_TOKEN=                # Access Token (account-level — generate under "Authentication Tokens")
X_ACCESS_TOKEN_SECRET=         # Access Token Secret (account-level)

# ── GitHub / Dashboard ────────────────────────────────────────────────────────
PAPERCLIP_GITHUB_REPO=vpjonny/probbrain   # GitHub repo for codebase + CI
# GitHub Actions secrets required: TELEGRAM_BOT_TOKEN, TELEGRAM_CHANNEL_ID,
#   DUB_LINK_TELEGRAM, POLYMARKET_API_URL
